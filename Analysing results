      "source": [
        "#use of Winobias - replacing profession with percentage of occupation reported as female\n",
        "\n",
        "#merging winobias data with gpt2 results\n",
        "gpt2results <- read_excel('/content/GPT2 results excel.xlsx', col_names = FALSE)\n",
        "colnames(gpt2results) <- unlist(gpt2results[2, ])\n",
        "gpt2results <- gpt2results[-c(1, 2), ]\n",
        "\n",
        "gpt2results$log_he_she_odds <- as.numeric(gpt2results$log_he_she_odds)\n",
        "gpt2results$tense <- as.factor(gpt2results$tense)\n",
        "gpt2results$semantic_role <- as.factor(gpt2results$semantic_role)\n",
        "gpt2results$syntactic_role <- as.factor(gpt2results$syntactic_role)\n",
        "gpt2results$valence <- as.factor(gpt2results$valence)\n",
        "gpt2results$dominance <- as.factor(gpt2results$dominance)\n",
        "gpt2results$profession <- as.factor(gpt2results$profession)\n",
        "\n",
        "winobias_data <- read_excel('/content/professions - Winobias.excel.xlsx', skip = 1)\n",
        "\n",
        "gpt2results$profession <- gsub(\"[^[:alnum:]]\", \"\", gpt2results$profession)\n",
        "gpt2results$profession <- tolower(trimws(gpt2results$profession))\n",
        "\n",
        "winobias_data$profession <- gsub(\"[^[:alnum:]]\", \"\", winobias_data$profession)\n",
        "winobias_data$profession <- tolower(trimws(winobias_data$profession))\n",
        "\n",
        "gpt2results_combined <- merge(gpt2results, winobias_data, by = \"profession\", all.x = TRUE)\n",
        "\n",
        "print(head(gpt2results_combined))\n",
        "\n",
        "# Verify no missing female_percentage values after re-cleaning\n",
        "unmatched_professions_after_reclean <- unique(gpt2results_combined$profession[is.na(gpt2results_combined$female_percentage)])\n",
        "if (length(unmatched_professions_after_reclean) == 0) {\n",
        "  cat(\"\\nAll professions successfully matched with female_percentage values.\")\n",
        "} else {\n",
        "  cat(\"\\nProfessions with missing female_percentage values after re-cleaning (not found in Winobias data):\\n\")\n",
        "  print(unmatched_professions_after_reclean)\n",
        "}\n",
        "\n"
      ]
    },
