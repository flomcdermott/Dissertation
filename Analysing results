      "source": [
        "#full mixed model\n",
        "gpt2_full_mixed = lmer(log_he_she_odds ~ (tense + syntactic_role + valence + dominance + semantic_role)^2 + (1+ semantic_role + syntactic_role| profession), data = gpt2results)\n",
        "summary_full_mixed <- summary(gpt2_full_mixed)\n",
        "rsquared_full_mixed <- r.squaredGLMM(gpt2_full_mixed)\n",
        "fixed_effects_full <- as.data.frame(summary_full_mixed$coefficients)\n",
        "random_effects_full <- as.data.frame(summary_full_mixed$varcor)\n",
        "model_summary_full <- list(\n",
        "  fixed_effects = fixed_effects_full,\n",
        "  random_effects = random_effects_full,\n",
        "  R2m = rsquared_full_mixed[1, \"R2m\"],\n",
        "  R2c = rsquared_full_mixed[1, \"R2c\"]\n",
        ")\n",
        "cat(\"\n",
        "--- GPT2 Full Mixed Model Summary --- \")\n",
        "\n",
        "cat(\"\n",
        "Fixed Effects: \")\n",
        "print(model_summary_full$fixed_effects)\n",
        "\n",
        "cat(\"\n",
        "Random Effects: \")\n",
        "print(model_summary_full$random_effects)\n",
        "\n",
        "cat(paste(\"\n",
        "Marginal R-squared (R2m): \", model_summary_full$R2m, \" \"))\n",
        "cat(paste(\"Conditional R-squared (R2c): \", model_summary_full$R2c, \" \"))\n",
        "\n",
        "cat(\"------------------------------------- \")\n",
