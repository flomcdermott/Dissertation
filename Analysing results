      "source": [
        "if (!require(lme4))\n",
        "  {install.packages(\"lme4\")}\n",
        "    library(lme4)\n",
        "\n",
        "if (!require(MuMIn))\n",
        "  {install.packages(\"MuMIn\")}\n",
        "    library(MuMIn)\n",
        "\n",
        "if (!require(readxl))\n",
        "  {install.packages(\"readxl\")}\n",
        "    library(readxl)\n",
        "# Read the Excel file into a data frame, specifying no column names initially\n",
        "gpt2results <- read_excel('/content/GPT2 results excel.xlsx', col_names = FALSE)\n",
        "# Use the second row as column names\n",
        "colnames(gpt2results) <- unlist(gpt2results[2, ])\n",
        "# Remove the first two rows (the original header and the one just used for names)\n",
        "gpt2results <- gpt2results[-c(1, 2), ]\n",
        "# Convert relevant columns to their correct types\n",
        "gpt2results$log_he_she_odds <- as.numeric(gpt2results$log_he_she_odds)\n",
        "gpt2results$tense <- as.factor(gpt2results$tense)\n",
        "gpt2results$semantic_role <- as.factor(gpt2results$semantic_role)\n",
        "gpt2results$syntactic_role <- as.factor(gpt2results$syntactic_role)\n",
        "gpt2results$valence <- as.factor(gpt2results$valence)\n",
        "gpt2results$dominance <- as.factor(gpt2results$dominance)\n",
        "gpt2results$profession <- as.factor(gpt2results$profession)\n",
        "cat(\"Data prepared and packages loaded successfully. \")"
      ]
    },
