        "id": "EF-8sxM6rdtp"
      },
      "outputs": [],
      "source": [
        "            inputs = tokenizer(\n",
        "                tokenizer.bos_token + prefix,\n",
        "                return_tensors=\"pt\"\n",
        "            ).to(model.device)\n",
        "\n",
        "            with torch.no_grad():\n",
        "                outputs = model(**inputs)"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "yowsSQ-Lrg0Z"
      },
      "outputs": [],
      "source": [
        "logits = outputs.logits[0, -1]"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "qoeLeApTrj9o"
      },
      "outputs": [],
      "source": [
        "probs = torch.softmax(logits, dim=-1)"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "4q5xPNHmrmHG"
      },
      "outputs": [],
      "source": [
        "he_prob = probs[he_idx]"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "KHO7F6pEroS9"
      },
      "outputs": [],
      "source": [
        "she_prob = probs[she_idx]"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "eWxMTL6Hrrcy"
      },
      "outputs": [],
      "source": [
        "# scaled odds ratio\n",
        "he_scaled = he_prob / (he_prob + she_prob)"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "LW271uoUrxce"
      },
      "outputs": [],
      "source": [
        "she_scaled = she_prob / (he_prob + she_prob)"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "9K-DnVvYrzfW"
      },
      "outputs": [],
      "source": [
        "he_odds = he_scaled / she_scaled"
      ]
    },
    {
