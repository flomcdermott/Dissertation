        "def get_det(noun, capitalise=False):\n",
        "    if noun[0].lower() in ('a', 'e', 'i', 'o', 'u'):\n",
        "        return 'An' if capitalise else 'an'\n",
        "    else:\n",
        "        return 'A' if capitalise else 'a'"
      ]
